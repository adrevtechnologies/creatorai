# Creator-AI Environment Configuration
# Copy to .env and fill in your values

# ============ SYSTEM CONFIGURATION ============
ENVIRONMENT=development  # development, staging, production
DEBUG=True
LOG_LEVEL=INFO
APP_NAME=Creator-AI
APP_PORT=8000
APP_HOST=0.0.0.0

# ============ DATABASE CONFIGURATION ============
# Supabase PostgreSQL (Free tier: 500MB storage, unlimited bandwidth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/creator_ai

# ============ CLOUD STORAGE ============
# AWS S3 (Free tier: 5GB storage for 12 months)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=creator-ai-content
S3_BUCKET_URL=https://creator-ai-content.s3.amazonaws.com

# ============ AI MODEL CONFIGURATION ============
# LLaMA/Mistral via Ollama (Self-hosted or via HuggingFace Spaces)
OLLAMA_API_URL=http://localhost:11434  # or remote Ollama server
TEXT_GENERATION_MODEL=mistral:7b  # or llama2:7b
TEXT_MODEL_TEMPERATURE=0.7
TEXT_MODEL_TOP_P=0.9

# Stable Diffusion XL (via HuggingFace or RunwayML)
IMAGE_GENERATION_API=huggingface  # huggingface, runwayml
HUGGINGFACE_API_KEY=hf_your_token_here
IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
IMAGE_QUALITY=high  # low, medium, high

# TTS (Coqui TTS)
TTS_MODEL=tts_models/en/ljspeech/glow-tts  # Free, high quality
TTS_DEVICE=cpu  # or cuda
VOICE_SPEED=1.0
VOICE_PITCH=1.0

# Video Processing (FFmpeg)
FFMPEG_PATH=ffmpeg  # PATH to ffmpeg binary
VIDEO_QUALITY=1080p
VIDEO_CODEC=libx264  # h264
VIDEO_AUDIO_CODEC=aac

# ============ PLATFORM API CREDENTIALS ============
# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxx

# TikTok Creator API
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token

# Instagram/Meta Graph API
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token
META_INSTAGRAM_ACCOUNT_ID=xxxxxxxxxxxxx

# Twitter/X API v2
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# ============ CONTENT STRATEGY ============
# Content niches to focus on (comma-separated)
CONTENT_NICHES=motivational,ai_trends,educational,entertainment

# Posting schedule (UTC timezone, 24-hour format)
POSTING_SCHEDULE=09:00,15:00,21:00  # Post 3x daily

# Batch size: pieces to generate per batch
BATCH_SIZE=5

# A/B test variants per piece
VARIANTS_PER_PIECE=3

# ============ ANALYTICS & MONITORING ============
# Sentry (Error tracking - free tier)
SENTRY_DSN=https://your-key@sentry.io/project-id

# Analytics (Segment or similar)
ANALYTICS_WRITE_KEY=your-segment-key

# Prometheus Metrics
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ============ SCHEDULING ============
# APScheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
CONTENT_GENERATION_SCHEDULE=cron
CONTENT_GENERATION_DAY_OF_WEEK=4  # Friday (0=Monday, 4=Friday)
CONTENT_GENERATION_HOUR=20  # 8 PM UTC

# ============ SECURITY ============
# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============ DEVELOPMENT & DEBUGGING ============
# VS Code & Agent Framework Debugging
DEBUGPY_ENABLED=false
DEBUGPY_PORT=5679
AGENT_DEV_CLI_VERBOSE=false

# Mock APIs (for testing without real credentials)
USE_MOCK_APIS=false

# ============ ADVANCED ============
# Webhook URL for external integrations
WEBHOOK_URL=

# Content cache TTL (seconds)
CACHE_TTL=3600

# Maximum concurrent operations
MAX_WORKERS=4

# Retry configuration
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Feature Flags
FEATURE_AUTO_OPTIMIZATION=true
FEATURE_DUPLICATE_DETECTION=true
FEATURE_CONTENT_MODERATION=true
